{
  "predictor_type": "learned",
  "schedule_trace_timeout": 5,
  "enable_data_collection": false,

  "model_estimator": {
    "type": "default",
    "score_type": "judge",
    "bucket_config": {
      "model_dir": "/mydata/models/route_balance/bucket_classifier",
      "model_map": {
        "Qwen/Qwen2.5-3B": "Qwen_Qwen2.5-3B_length_bucket",
        "Qwen/Qwen2.5-7B": "Qwen_Qwen2.5-7B_length_bucket",
        "Qwen/Qwen2.5-14B": "Qwen_Qwen2.5-14B_length_bucket",
        "Qwen/Qwen2.5-72B": "Qwen_Qwen2.5-72B_length_bucket"
      },
      "bucket_size": 64,
      "max_buckets": 16,
      "max_length": 1024
    },
    "quality_config": {
      "type": "knn",
      "model_dir": "/mydata/models/route_balance/knn_quality",
      "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
      "k": 10
    }
  },

  "bucket_classifier": {
    "model_dir": "/mydata/models/route_balance/bucket_classifier",
    "encoder_name": "answerdotai/ModernBERT-base",
    "bucket_size": 64,
    "max_buckets": 16,
    "max_length": 1024,
    "model_map": {
      "Qwen/Qwen2.5-3B": "Qwen_Qwen2.5-3B_length_bucket",
      "Qwen/Qwen2.5-7B": "Qwen_Qwen2.5-7B_length_bucket",
      "Qwen/Qwen2.5-14B": "Qwen_Qwen2.5-14B_length_bucket",
      "Qwen/Qwen2.5-72B": "Qwen_Qwen2.5-72B_length_bucket"
    }
  },

  "xgboost_ttft": {
    "model_dir": "/mydata/models/route_balance/xgboost_ttft"
  },

  "tpot_lookup": {
    "qwen2.5-3b_p100": 0.045,
    "qwen2.5-3b_a30": 0.025,
    "qwen2.5-7b_a30": 0.035,
    "qwen2.5-14b_v100": 0.055,
    "qwen2.5-72b_a100": 0.065
  },

  "quality_predictor": {
    "type": "knn",
    "model_dir": "/mydata/models/route_balance/knn_quality",
    "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
    "k": 10
  },

  "instance_metadata": {
    "qwen2.5-3b_p100": {
      "model_name": "Qwen/Qwen2.5-3B",
      "gpu_type": "p100",
      "cost_per_token": 0.001
    },
    "qwen2.5-3b_a30": {
      "model_name": "Qwen/Qwen2.5-3B",
      "gpu_type": "a30",
      "cost_per_token": 0.002
    },
    "qwen2.5-7b_a30": {
      "model_name": "Qwen/Qwen2.5-7B",
      "gpu_type": "a30",
      "cost_per_token": 0.003
    },
    "qwen2.5-14b_v100": {
      "model_name": "Qwen/Qwen2.5-14B",
      "gpu_type": "v100",
      "cost_per_token": 0.005
