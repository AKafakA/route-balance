{
  "predictor_type": "learned",
  "schedule_trace_timeout": 5,
  "enable_data_collection": false,

  "model_estimator": {
    "type": "pfs",
    "model_names": ["Qwen/Qwen2.5-3B", "Qwen/Qwen2.5-7B"],
    "window_size": 1000,
    "use_input_bins": true,
    "bucket_size": 64,
    "max_buckets": 16,
    "train_data_path": "/users/asdwb/Block/data/route_balance/training_data/train_fixed.jsonl"
  },

  "xgboost_ttft": {
    "model_dir": "/users/asdwb/Block/models/route_balance/latency/deploy"
  },

  "tpot_lookup": {
    "qwen2.5-3b_d7525": 0.025,
    "qwen2.5-7b_d7525": 0.035
  },

  "quality_predictor": {
    "type": "knn",
    "model_dir": "/users/asdwb/Block/models/route_balance/quality/judge/deploy",
    "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
    "k": 10
  },

  "instance_metadata": {
    "qwen2.5-3b_d7525": {
      "model_name": "Qwen/Qwen2.5-3B",
      "gpu_type": "a30",
      "cost_per_token": 0.002
    },
    "qwen2.5-7b_d7525": {
      "model_name": "Qwen/Qwen2.5-7B",
      "gpu_type": "a30",
      "cost_per_token": 0.003
    }
  },

  "scoring_weights": {
    "w_latency": 0.3,
    "w_cost": 0.2,
    "w_quality": 0.3,
    "w_balance": 0.2
  },

  "slo_defaults": {
    "ttft_slo_ms": 10000,
    "tpot_slo_ms": 200,
    "budget_tokens": 256,
    "quality_min": 0.0,
    "budget_confidence_threshold": 0.5,
    "constraint_mode": "TIERED",
    "relax_order": ["ttft", "tpot", "quality", "budget"],
    "lpt_sort_key": "max",
    "batch_config": {
      "max_batch_size": 8,
      "batch_timeout_ms": 100,
      "adaptive_sizing": true
    },
    "instance_capacity": {
      "qwen2.5-3b_d7525": 10,
      "qwen2.5-7b_d7525": 6
    }
  }
}
